# Telegram
# Required for demo run: create a demo bot via BotFather and paste its token here.
BOT_TOKEN=your_demo_telegram_bot_token

# Required for admin demo features: your numeric Telegram user ID.
ADMIN_IDS=your_numeric_telegram_id

# Required for portfolio/demo mode: keep true to use fake payment buttons instead of YooKassa.
TEST_MODE=true

# YooKassa
# Optional. Leave empty for demo mode because production payments are not connected.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Webhook
# Required only for production webhook mode. Not needed for local polling demo.
WEBHOOK_DOMAIN=https://your-demo-domain.example
WEBHOOK_PATH=/telegram
YOOKASSA_WEBHOOK_PATH=/webhook/yookassa

# Server
# Required for local demo run.
PORT=3000
NODE_ENV=development

# Paths
# Optional. Defaults are suitable for local demo run.
DB_PATH=./data/bot.db
SUBSCRIPTIONS_PATH=./config/subscriptions.json
NOTIFIERS_PATH=./config/notifiers.json

# Demo club info
# Used in messages after successful demo payment.
CLUB_NAME=FitAdmin Demo Club
CLUB_ADDRESS=Demo City, 10 Portfolio Street
CLUB_PHONE=+7 000 000-00-00
CLUB_HOURS=Пн–Пт 07:00–22:00, Сб–Вс 09:00–21:00
